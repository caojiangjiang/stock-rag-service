# Stock RAG 服务环境变量配置
# 复制此文件为 .env 并填写实际值

# 服务端口
PORT=8080
GO_ENV=production

# Supabase PostgreSQL 配置
DB_HOST=db.uvbojcqbfobmqrjturza.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_supabase_password
DB_NAME=postgres
DB_SSLMODE=require

# Redis 配置（可选）
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# 火山引擎 ARK API
ARK_API_KEY=your_ark_api_key
ARK_MODEL=doubao-seed-2-0-pro-260215

# JWT 密钥（生成随机字符串）
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
# 访问令牌有效期（分钟）、刷新令牌（天）
# JWT_ACCESS_TTL_MINUTES=15
# JWT_REFRESH_TTL_DAYS=7
# 注册/登录时匹配该用户名的账号为 admin
# ADMIN_USERNAME=admin

# LLM 配置
LLM_MAX_QUEUE_SIZE=100
LLM_MAX_CONCURRENCY=10
LLM_MAX_WAIT_TIME_MS=30000

# OTLP 可观测性配置（兼容 Jaeger、GrafanaCloud、Signoz、OTel Collector 等）
# 注意：值只需 host:port，OTLP HTTP 客户端会自动追加 /v1/traces 路径
# 本地 Jaeger（docker compose --profile monitoring）:
OTLP_ENDPOINT=localhost:4318
# 结构化日志写入文件，供 Promtail → Loki；Grafana 用 trace_id 关联 Trace
LOG_FILE=logs/app.log
# GrafanaCloud:
# OTLP_ENDPOINT=otlp-gateway-prod-us-central1.grafana.net
# OTLP_USER=your_user_id
# OTLP_KEY=your_service_account_token

# Agent 执行器：supervisor（默认，多 Agent 协调）或 react（ReAct 思考-行动-观察循环）
# AGENT_EXECUTOR=react

# 多 Agent 协调器：supervisor | plan | pipeline | workflow | peer
# COORDINATOR_TYPE=workflow
