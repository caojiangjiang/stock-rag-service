# Stock RAG 服务环境变量配置
# 复制此文件为 .env 并填写实际值

# 服务端口
PORT=8080
GO_ENV=production

# Supabase PostgreSQL 配置
DB_HOST=db.uvbojcqbfobmqrjturza.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_supabase_password
DB_NAME=postgres
DB_SSLMODE=require

# Redis 配置（可选）
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# 火山引擎 ARK API
ARK_API_KEY=your_ark_api_key
ARK_MODEL=doubao-seed-2-0-pro-260215

# JWT 密钥（生成随机字符串）
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

# LLM 配置
LLM_MAX_QUEUE_SIZE=100
LLM_MAX_CONCURRENCY=10
LLM_MAX_WAIT_TIME_MS=30000

# OTLP 可观测性配置（兼容 Jaeger、GrafanaCloud、Signoz、OTel Collector 等）
# 注意：值只需 host:port，OTLP HTTP 客户端会自动追加 /v1/traces 路径
# 本地 Jaeger（docker-compose.jaeger.yaml）:
OTLP_ENDPOINT=localhost:4318
# GrafanaCloud:
# OTLP_ENDPOINT=otlp-gateway-prod-us-central1.grafana.net
# OTLP_USER=your_user_id
# OTLP_KEY=your_service_account_token
